# ══════════════════════════════════════════════════════════════════
#  secrets.toml.example  —  이 파일을 복사해 secrets.toml 로 사용하세요.
#
#  Streamlit Community Cloud 배포 시:
#    앱 대시보드 → Settings → Secrets 에 아래 내용을 그대로 붙여넣기
# ══════════════════════════════════════════════════════════════════

[openai]
api_key = "sk-REPLACE_WITH_YOUR_REAL_OPENAI_API_KEY"

[auth]
# 비밀번호 해싱 pepper — 임의의 긴 문자열로 반드시 변경하세요
pepper = "CHANGE_THIS_TO_A_LONG_RANDOM_STRING"

# ── 관리자 계정 ─────────────────────────────────────────────────
# python make_hash.py 로 비밀번호 해시를 생성하세요

[users.admin]
name     = "관리자"
password = "HASH_GENERATED_BY_make_hash.py"

# 추가 관리자 계정 예시:
# [users.manager]
# name     = "매니저"
# password = "HASH_GENERATED_BY_make_hash.py"
